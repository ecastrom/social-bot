# -- Anthropic API (for content generation) --------------------------------
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# -- GitHub API (for issue-based approval pipeline) ------------------------
# Create a personal access token at: https://github.com/settings/tokens
# Required scopes: repo (for creating/reading/closing issues)
GITHUB_TOKEN=your_github_token_here

# -- Threads (Meta) API ---------------------------------------------------
# Set up at: https://developers.facebook.com/apps/
# Enable the "Threads API" product, then get a Long-Lived Access Token.
# The token expires every 60 days — refresh it before it lapses.
THREADS_APP_ID=your_app_id_here
THREADS_APP_SECRET=your_app_secret_here
THREADS_ACCESS_TOKEN=your_long_lived_token_here
THREADS_USER_ID=your_threads_numeric_user_id_here
